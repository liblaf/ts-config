  "repository": "github:liblaf/ts-config",
  "funding": {
    "type": "github",
    "url": "https://github.com/liblaf/ts-config?sponsor=1"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    "./oxlint": {
      "import": {
        "types": "./dist/oxlint.config.d.ts",
        "default": "./dist/oxlint.config.js"
      }
    },
    "./oxfmt": {
      "import": {
        "types": "./dist/oxfmt.config.d.ts",
        "default": "./dist/oxfmt.config.js"
      }
    },
    "./bunup": {
      "import": {
        "types": "./dist/bunup.config.d.ts",
        "default": "./dist/bunup.config.js"
      }
    },
    "./tsconfig": "./dist/tsconfig.json",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "bunup",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "prepack": "bun run build",
    "type-check": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "25.6.0",
    "bunup": "0.16.31",
    "oxfmt": "0.47.0",
    "oxlint": "1.61.0",
    "oxlint-tsgolint": "0.22.1",
    "typescript": "6.0.3"
  },
  "peerDependencies": {
    "bunup": "^0.16",
    "oxfmt": "^0.46 || ^0.47.0",
    "oxlint": "^1",
    "oxlint-tsgolint": "^0.22",
    "typescript": "^6"
  },
  "peerDependenciesMeta": {
    "bunup": {
      "optional": true
    },
    "oxfmt": {
      "optional": true
    },
    "oxlint": {
      "optional": true
    },
    "oxlint-tsgolint": {
      "optional": true
    }
  },
  "readme": "./README.md"
}
